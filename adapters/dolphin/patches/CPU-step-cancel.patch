-// Requires m_state_change_lock
+bool CPUManager::CancelStepOpcode(Common::Event* event)
+{
+  std::lock_guard state_lock(m_state_change_lock);
+
+  // A completed or superseded request no longer retains this event. In that case the caller may
+  // restore the previous core mode only after the CPU thread has also become idle.
+  if (m_state_cpu_step_instruction_sync != event)
+    return !m_state_cpu_thread_active;
+
+  // Detach the caller-owned event before it leaves scope. If SingleStep is already executing, it
+  // may still finish later, so report that the caller must leave the interpreter selected.
+  m_state_cpu_step_instruction_sync = nullptr;
+  m_state_cpu_step_instruction = false;
+  return !m_state_cpu_thread_active;
+}
+
+// Requires m_state_change_lock
 bool CPUManager::SetStateLocked(State s)
