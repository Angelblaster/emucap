+bool SaveAsSynchronous(Core::System& system, std::string filename)
+{
+  const auto buffer_size_estimate = std::size_t(s_last_state_size) * 110 / 100;
+  Common::UniqueBuffer<u8> buffer{buffer_size_estimate};
+  std::size_t actual_size = 0;
+  {
+    Core::CPUThreadGuard guard(system);
+    actual_size = SaveToBuffer(system, buffer);
+  }
+  if (actual_size == 0)
+    return false;
+
+  buffer.assign(buffer.extract().first, actual_size);
+  CompressAndDumpStateArgs dump_args{
+      .buffer = std::move(buffer),
+      .filename = filename,
+      .task_lock = GetStateSaveTaskLock(),
+  };
+  CompressAndDumpState(system, dump_args);
+
+  StateHeader header;
+  return ReadHeader(filename, header);
+}
