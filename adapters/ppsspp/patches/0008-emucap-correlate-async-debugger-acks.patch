+static std::string RequestTicket(const JsonGet &data) {
+	const JsonNode *value = data.get("ticket");
+	return value ? json_stringify(value) : "";
+}
+
+void SteppingBroadcaster::ExpectRequest(const char *event, const JsonGet &data) {
+	std::string ticket = RequestTicket(data);
+	if (ticket.empty())
+		return;
+
+	if (!strcmp(event, "cpu.resume")) {
+		resumeTickets_.push_back(std::move(ticket));
+	} else if (!strcmp(event, "cpu.stepping") ||
+		!strcmp(event, "cpu.stepInto") ||
+		!strcmp(event, "cpu.stepOver") ||
+		!strcmp(event, "cpu.stepOut") ||
+		!strcmp(event, "cpu.runUntil") ||
+		!strcmp(event, "cpu.nextHLE")) {
+		steppingTickets_.push_back(std::move(ticket));
+	}
+}
