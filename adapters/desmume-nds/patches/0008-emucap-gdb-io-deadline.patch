+#define EMUCAP_GDB_IO_DEADLINE_MS 2000
+#define EMUCAP_GDB_SOCKET_TIMEOUT_MS 250
+#define EMUCAP_GDB_ACK_ATTEMPTS 3
+
+typedef std::chrono::steady_clock emucap_gdb_clock;
+
+static int emucap_socket_retryable(void) {
+#ifdef WIN32
+  int error = WSAGetLastError();
+  return error == WSAEWOULDBLOCK || error == WSAETIMEDOUT || error == WSAEINTR;
+#else
+  return errno == EAGAIN || errno == EWOULDBLOCK || errno == EINTR;
+#endif
+}
+
+static int emucap_set_socket_io_timeout(SOCKET_TYPE sock) {
+#ifdef WIN32
+  DWORD timeout = EMUCAP_GDB_SOCKET_TIMEOUT_MS;
+  int send_res = setsockopt(sock, SOL_SOCKET, SO_SNDTIMEO,
+                            (const char *)&timeout, sizeof(timeout));
+  int recv_res = setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO,
+                            (const char *)&timeout, sizeof(timeout));
+#else
+  struct timeval timeout;
+  timeout.tv_sec = EMUCAP_GDB_SOCKET_TIMEOUT_MS / 1000;
+  timeout.tv_usec = (EMUCAP_GDB_SOCKET_TIMEOUT_MS % 1000) * 1000;
+  int send_res = setsockopt(sock, SOL_SOCKET, SO_SNDTIMEO, &timeout, sizeof(timeout));
+  int recv_res = setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout));
+#endif
+  return send_res == 0 && recv_res == 0 ? 0 : -1;
+}
+
+static int emucap_send_all_until(
+    SOCKET_TYPE sock, const char *data, size_t len,
+    const emucap_gdb_clock::time_point &deadline) {
+  size_t sent = 0;
+  while (sent < len && emucap_gdb_clock::now() < deadline) {
+    int n = send(sock, (char *)(data + sent), (int)(len - sent), 0);
+    if (n > 0) {
+      sent += (size_t)n;
+    } else if (n == 0 || !emucap_socket_retryable()) {
+      return -1;
+    }
+  }
+  return sent == len ? 0 : -1;
+}
+
+static int emucap_recv_ack_until(
+    SOCKET_TYPE sock, uint8_t *reply,
+    const emucap_gdb_clock::time_point &deadline) {
+  while (emucap_gdb_clock::now() < deadline) {
+    int n = recv(sock, (char *)reply, 1, 0);
+    if (n == 1) return 0;
+    if (n == 0 || !emucap_socket_retryable()) return -1;
+  }
+  return -1;
+}
